[Unit]
Description=NVIDIA to OpenAI Proxy Server
Documentation=https://github.com/your-repo/nvidia-to-openai-proxy
After=network.target

[Service]
Type=simple
User=nvidia-proxy
Group=nvidia-proxy
WorkingDirectory=/opt/nvidia-to-openai-proxy
ExecStart=/usr/bin/node server.js
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal
SyslogIdentifier=nvidia-proxy

# 环境变量（也可使用 EnvironmentFile=/opt/nvidia-to-openai-proxy/.env）
Environment=NODE_ENV=production
Environment=PORT=3000
Environment=NVIDIA_API_KEY=your-api-key-here

# 资源限制
LimitNOFILE=65536
LimitNPROC=4096

# 安全设置
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/opt/nvidia-to-openai-proxy/logs

[Install]
WantedBy=multi-user.target
